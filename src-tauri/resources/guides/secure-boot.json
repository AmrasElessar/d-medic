{
  "id": "secure-boot",
  "title": {
    "tr": "Secure Boot Etkinleştirme",
    "en": "Enable Secure Boot"
  },
  "priority": "ORTA",
  "estimated_time": "5 dk",
  "risk": "LOW",
  "prerequisites": ["uefi_modu", "gpt_disk"],
  "steps": [
